{
  "name": "Azure Data Engineering Dataset",
  "description": "Dataset connecting to Synapse gold.customer_summary table",
  "source": {
    "type": "Synapse",
    "server": "<synapse_server>.sql.azuresynapse.net",
    "database": "<database_name>",
    "table": "gold.customer_summary"
  },
  "columns": [
    {
      "name": "age_group",
      "type": "string"
    },
    {
      "name": "total_customers",
      "type": "integer"
    },
    {
      "name": "total_age",
      "type": "integer"
    }
  ]
}